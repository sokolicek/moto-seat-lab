---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import Questionnaire from "../../../../components/Questionnaire.astro";
import SeatComfortEstimator from "../../../../components/SeatComfortEstimator.astro";
import SeatLayerGraphic from "../../../../components/SeatLayerGraphic.astro";
import RiderProfileCard from "../../../../components/RiderProfileCard.astro";
import SolutionCard from "../../../../components/SolutionCard.astro";
import SeatOptionCard from "../../../../components/SeatOptionCard.astro";
import SeatOptionAdvisor from "../../../../components/SeatOptionAdvisor.astro";
import solutionPaths from "../../../../data/solution-paths/seat-comfort.json";
import productCategories from "../../../../data/product-categories/seat-comfort.json";
import seatOptions from "../../../../data/products/gsx-s1000gx-seat-options.json";
import riderProfiles from "../../../../data/rider-profiles/gsx-s1000gx.json";
import sources from "../../../../data/sources/suzuki-gsx-s1000gx.json";
import disclosures from "../../../../data/disclosures/de.json";
---

<BaseLayout
  title="Suzuki GSX-S1000GX Sitzbank Komfort: Schmerzen nach einer Stunde?"
  description="Praktischer Guide für GSX-S1000GX Fahrer: Ursachen, schnelle Tests, OEM/Aftermarket/Sattler und DIY ohne falsche Versprechen."
  canonicalPath="/de/motorrad-sitzbank/suzuki-gsx-s1000gx/"
>
  <section class="hero video-hero gsx-video-hero">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/assets/hero/touring-forest-curve.webp"
      aria-hidden="true"
    >
      <source src="/assets/video/gsx-s1000gx-forest-curve.mp4" type="video/mp4" />
    </video>
    <div class="page-inner hero-grid video-hero-inner">
      <div class="video-hero-copy">
        <p class="eyebrow">Suzuki GSX-S1000GX · Deutschland</p>
        <h1>Sitzbank-Schmerzen nach einer Stunde? Erst die Ursache finden, dann kaufen.</h1>
        <p class="lead">
          Die GSX-S1000GX ist ein sportlicher Tourer. Komfort hängt nicht nur von der Sitzbank ab,
          sondern auch von Sitzform, Haltung, Knie­winkel, Kleidung, Hitze und Fahrdauer.
        </p>
        <div class="spec-strip" aria-label="MVP Kontext">
          <span>Modell: Suzuki GSX-S1000GX</span>
          <span>Land: Deutschland</span>
          <span>Status: MVP Recherche</span>
        </div>
        <div class="actions">
          <a class="button" href="#quick-check-title">Schnellcheck starten</a>
          <a class="button secondary" href="#loesungen">Lösungen vergleichen</a>
        </div>
        <div class="hero-stats" aria-label="Guide Schwerpunkte">
          <span><strong>45-90 min</strong><small>typischer Komfortbruch</small></span>
          <span><strong>4 Optionen</strong><small>Serie, Auflage, Kauf, Umbau</small></span>
          <span><strong>MVP</strong><small>Quellen werden markiert</small></span>
        </div>
        <div class="media-note">
          <p class="asset-note">Video-Hintergrund aus lokalem MVP-Asset, ohne Ton.</p>
          <button class="video-toggle" type="button" aria-pressed="false" data-video-toggle>
            Video pausieren
          </button>
        </div>
      </div>
      <SeatLayerGraphic />
    </div>
  </section>

  <script>
    window.localStorage.setItem("motoseatlab_last_motorcycle", "suzuki-gsx-s1000gx");

    const heroVideo = document.querySelector<HTMLVideoElement>(".hero-video");
    const videoToggle = document.querySelector<HTMLButtonElement>("[data-video-toggle]");
    const videoStorageKey = "motoseatlab_gsx_video_paused";

    const setVideoState = (paused: boolean) => {
      if (!heroVideo || !videoToggle) return;
      videoToggle.setAttribute("aria-pressed", paused.toString());
      videoToggle.textContent = paused ? "Video abspielen" : "Video pausieren";
      if (paused) {
        heroVideo.pause();
      } else {
        heroVideo.play().catch(() => {
          videoToggle.textContent = "Video abspielen";
          videoToggle.setAttribute("aria-pressed", "true");
        });
      }
    };

    if (heroVideo && videoToggle) {
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const storedPaused = window.localStorage.getItem(videoStorageKey) === "true";
      const shouldPause = prefersReducedMotion || storedPaused;
      setVideoState(shouldPause);

      videoToggle.addEventListener("click", () => {
        const nextPaused = !heroVideo.paused;
        window.localStorage.setItem(videoStorageKey, nextPaused.toString());
        setVideoState(nextPaused);
      });
    }
  </script>

  <section class="section compact-nav-section">
    <div class="page-inner">
      <nav class="page-jump-nav" aria-label="Seitensprungmarken">
        <a href="#quick-check-title">Schnellcheck</a>
        <a href="#loesungen">Lösungswege</a>
        <a href="#optionen">Optionen</a>
        <a href="#option-advisor-title">Mini-Berater</a>
        <a href="#quellen">Quellen</a>
      </nav>
    </div>
  </section>

  <section class="section visual-band">
    <div class="page-inner grid three-feature">
      <article>
        <span class="metric">01</span>
        <h2>Druck ist nicht nur Härte.</h2>
        <p>
          Zu weicher Schaum kann durchsitzen, zu schmaler Schaum kann punktuell drücken,
          und ein falscher Winkel kann dich immer wieder in dieselbe Stelle schieben.
        </p>
      </article>
      <article>
        <span class="metric">02</span>
        <h2>Hitze verändert Komfort.</h2>
        <p>
          Im Sommer fühlen sich Bezug, Hose, Luftzirkulation und Gel anders an als im Frühjahr.
          Deshalb sind Testbedingungen wichtig.
        </p>
      </article>
      <article>
        <span class="metric">03</span>
        <h2>Ergonomie sitzt mit.</h2>
        <p>
          Sitzhöhe, Fußrasten, Lenkerreichweite und Winddruck entscheiden mit,
          wie viel Gewicht auf der Sitzbank bleibt.
        </p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="page-inner grid two">
      <Questionnaire />
      <SeatComfortEstimator />
    </div>
  </section>

  <section class="section alt">
    <div class="page-inner">
      <h2>Welche Art Fahrer bist du?</h2>
      <p class="lead">
        Die gleiche Sitzbank kann für kurze Runden reichen und auf Tour trotzdem scheitern.
        Starte deshalb mit deiner echten Nutzung, nicht mit einem Produktnamen.
      </p>
      <div class="grid">
        {riderProfiles.map((profile) => <RiderProfileCard {...profile} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="page-inner grid two">
      <article class="card">
        <h2>Für wen ist dieser Guide?</h2>
        <p>
          Für Fahrer, die mit der originalen GSX-S1000GX Sitzbank nach etwa 45 bis 90 Minuten Probleme bekommen
          und nicht wissen, ob sie eine Auflage, einen OEM-Sitz, einen Aftermarket-Sitz, einen Sattler oder DIY wählen sollen.
        </p>
        <ul class="tag-list">
          <li>Touring</li>
          <li>Landstraße</li>
          <li>Druckpunkte</li>
          <li>Hitze</li>
          <li>Sitzhöhe</li>
        </ul>
      </article>
      <article class="card">
        <h2>Was du dieses Wochenende testen kannst</h2>
        <ol class="steps">
          <li>Eine 60- bis 90-Minuten-Fahrt mit Notizen zu Schmerzstelle, Temperatur und Hose fahren.</li>
          <li>Prüfen, ob du beim Bremsen oder in normaler Haltung nach vorne rutschst.</li>
          <li>Eine dünne, reversible Auflage oder 3D-Mesh testen, aber nur einzeln, nicht alles gleichzeitig.</li>
          <li>Nach der Fahrt vergleichen: gleicher Weg, ähnliche Temperatur, gleiche Kleidung.</li>
        </ol>
      </article>
    </div>
  </section>

  <section class="section alt" id="loesungen">
    <div class="page-inner">
      <h2>Realistische Lösungswege</h2>
      <p class="lead">
        Die Reihenfolge ist für Deutschland und sportliches Touring gedacht. Für Scooter- und Low-Budget-Märkte
        wäre die Reihenfolge anders.
      </p>
      <div class="grid">
        {solutionPaths.map((path) => <SolutionCard {...path} />)}
      </div>
    </div>
  </section>

  <section class="section" id="optionen">
    <div class="page-inner">
      <p class="eyebrow">Erster Research-Shortlist</p>
      <h2>Konkrete Optionen für die GSX-S1000GX</h2>
      <p class="lead">
        Diese Karten sind noch kein Ranking. Sie zeigen, welche Optionen als erstes in die Datenbank gehoeren:
        OEM, Aftermarket, reversible Tests und Sattler-Umbau.
      </p>
      <div class="grid two">
        {seatOptions.map((option) => <SeatOptionCard {...option} />)}
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="page-inner">
      <SeatOptionAdvisor />
    </div>
  </section>

  <section class="section">
    <div class="page-inner grid two">
      <article>
        <h2>Was du zuerst prüfen solltest</h2>
        <div class="card">
          <h3>1. Wo genau tut es weh?</h3>
          <p>Sitzknochen, Steißbein, Innenschenkel, Knie/Hüfte oder taubes Gefühl sind unterschiedliche Probleme.</p>
          <h3>2. Rutschst du nach vorne?</h3>
          <p>Dann kann der Sitzwinkel oder Bezug wichtiger sein als mehr Polsterung.</p>
          <h3>3. Wird es im Sommer schlimmer?</h3>
          <p>Dann können 3D-Mesh, Kleidung und Bezugsmaterial sinnvoller sein als Gel.</p>
        </div>
      </article>
      <article>
        <h2>Produktkategorien für erste Tests</h2>
        <div class="grid">
          {productCategories.map((category) => (
            <article class="card">
              <h3>{category.name}</h3>
              <p><strong>Hilft bei:</strong> {category.problemSolved}</p>
              <p><strong>Grenze:</strong> {category.limitations}</p>
              <p><strong>Preis:</strong> {category.priceBand}</p>
            </article>
          ))}
        </div>
      </article>
    </div>
  </section>

  <section class="section alt">
    <div class="page-inner">
      <h2>Seriensitz vs. mögliche Lösungen</h2>
      <p class="lead">
        Die Werte sind bewusst qualitativ, bis verifizierte Messdaten und echte Produktdaten eingepflegt sind.
      </p>
      <div class="comparison-table" role="table" aria-label="Sitzbank Vergleich">
        <div class="comparison-row header" role="row">
          <span role="columnheader">Option</span>
          <span role="columnheader">Stärke</span>
          <span role="columnheader">Risiko</span>
          <span role="columnheader">Wann sinnvoll?</span>
        </div>
        <div class="comparison-row" role="row">
          <span role="cell">Seriensitz</span>
          <span role="cell">passt zum Motorrad, keine Umbauten</span>
          <span role="cell">kann nach 45-90 Minuten Druck erzeugen</span>
          <span role="cell">Referenz für alle Tests</span>
        </div>
        <div class="comparison-row" role="row">
          <span role="cell">3D-Mesh / dünne Auflage</span>
          <span role="cell">billig, reversibel, gut bei Hitze</span>
          <span role="cell">ändert Sitzhöhe und Gefühl</span>
          <span role="cell">erster Test vor teuren Käufen</span>
        </div>
        <div class="comparison-row" role="row">
          <span role="cell">OEM / Aftermarket</span>
          <span role="cell">sauber, schnell, wiederverkaufbar</span>
          <span role="cell">teuer und nicht automatisch passend</span>
          <span role="cell">wenn Rückgabe und echte Erfahrungsberichte passen</span>
        </div>
        <div class="comparison-row" role="row">
          <span role="cell">Sattler / DIY</span>
          <span role="cell">Form kann gezielt verändert werden</span>
          <span role="cell">Qualität, Abdichtung und Rückbau beachten</span>
          <span role="cell">bei klarer Schmerzstelle oder Spezialanforderung</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="page-inner grid two">
      <article class="notice">
        <h2>Wichtige Warnungen</h2>
        <p>Weicher ist nicht automatisch bequemer. Wenn Schaum durchsitzt, steigt der Druck oft.</p>
        <p>Gel kann Hitze speichern und löst keine falsche Sitzform.</p>
        <p>Eine niedrigere Sitzbank kann den Bodenkontakt verbessern, aber Kniewinkel und Langstreckenkomfort verschlechtern.</p>
      </article>
      <article class="card">
        <h2>Offene Recherche</h2>
        <p>
          Konkrete GSX-S1000GX Produktdaten, deutsche Preise, Rückgaberegeln und echte Besitzerberichte
          müssen noch verifiziert werden.
        </p>
        <p><strong>Affiliate-Hinweis:</strong> {disclosures.affiliate}</p>
      </article>
    </div>
  </section>

  <section class="section" id="quellen">
    <div class="page-inner">
      <h2>Quellen und Vertrauensniveau</h2>
      <div class="grid">
        {sources.map((source) => (
          <article class="card">
            <span class="badge">Confidence {source.confidence}/5</span>
            <h3>{source.title}</h3>
            <p>{source.notes}</p>
            <p><a href={source.url}>Quelle öffnen</a></p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
