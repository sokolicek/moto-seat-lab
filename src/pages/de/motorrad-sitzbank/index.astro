---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import LabDataCard from "../../../components/LabDataCard.astro";
import motorcycles from "../../../data/motorcycles/de-list.json";
import technicalProfiles from "../../../data/motorcycles/technical-profiles.json";
import { getMediaForEntity } from "../../../lib/mediaAssets";

const activeMotorcycles = motorcycles.filter((motorcycle) => motorcycle.status === "active");
const plannedMotorcycles = motorcycles.filter((motorcycle) => motorcycle.status !== "active");
const slugifyMotorcycleName = (name: string) => name.toLowerCase().replaceAll("/", "").replaceAll(" ", "-");
const motorcyclesBySlug = new Map(
  motorcycles.map((motorcycle) => {
    const slug = motorcycle.path.split("/").filter(Boolean).at(-1) ?? slugifyMotorcycleName(motorcycle.name);
    return [slug, motorcycle];
  })
);

const profileLabel: Record<string, string> = {
  sport_touring: "Sport-Touring",
  country_road: "Landstraße",
  highway: "Autobahn",
  weekend_touring: "Wochenende",
  adventure_touring: "Adventure Touring",
  two_up: "Sozius",
  long_distance: "Langstrecke",
  used_market: "Gebrauchtmarkt",
  adventure: "Adventure",
  travel: "Reise",
  light_offroad: "leichtes Gelände",
};

const riskLabel: Record<string, string> = {
  pressure_after_60_min: "Druck nach 60 Min.",
  heat: "Hitze",
  forward_slide: "Vorrutschen",
  knee_angle: "Kniewinkel",
  seat_height: "Sitzhöhe",
  long_distance_pressure: "Langstreckendruck",
  passenger_comfort: "Soziuskomfort",
  accessory_choice_overload: "zu viele Zubehör-Optionen",
  touring_pressure: "Touring-Druck",
  wind_pressure: "Winddruck",
  standing_transition: "Sitzen/Stehen Wechsel",
};

const measurementLabel: Record<string, string> = {
  seat_height_mm: "Sitzhöhe",
  usable_seat_width_sitbone_zone_mm: "nutzbare Breite im Sitzknochenbereich",
  seat_pan_slope_deg: "Sitzwannenneigung",
  footpeg_to_seat_vertical_mm: "Fußrasten-Sitz-Höhe",
  handlebar_reach_mm: "Lenkerreichweite",
  seat_width_mm: "Sitzbreite",
  footpeg_position_mm: "Fußrastenposition",
  seat_options_oem_aftermarket: "OEM/Aftermarket Sitzoptionen",
  seat_slope_deg: "Sitzneigung",
  wind_pressure_notes: "Winddruck-Notizen",
  low_high_seat_positions: "niedrige/hohe Sitzposition",
  standing_clearance: "Stehfreiheit",
};
---

<BaseLayout
  title="Motorräder: Sitzbank-Komfort nach Modell"
  description="Moto Seat Lab Motorradliste: starte mit deinem Modell, zuletzt bearbeitet ist Suzuki GSX-S1000GX."
  canonicalPath="/de/motorrad-sitzbank/"
>
  <section class="hero">
    <div class="page-inner">
      <p class="eyebrow">Motorräder</p>
      <h1>Wähle dein Motorrad. Wir starten mit Suzuki.</h1>
      <p class="lead">
        Die Navigation führt jetzt nicht mehr direkt in ein einzelnes Modell. Diese Liste wird später
        nach Land, Segment und typischen Sitzbankproblemen erweitert.
      </p>
      <div class="actions">
        <a class="button" href="/de/motorrad-sitzbank/suzuki-gsx-s1000gx/">Suzuki GSX-S1000GX öffnen</a>
        <a class="button secondary" href="#geplant">Geplante Modelle ansehen</a>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="page-inner grid two">
      <article class="card last-bike-card">
        <span class="badge">Zuletzt angesehen</span>
        <h2 id="last-bike-title">Suzuki GSX-S1000GX</h2>
        <p id="last-bike-note">
          Dieses Modell ist aktuell der Referenz-Guide für Deutschland und wird beim nächsten Besuch
          wieder zuerst angeboten.
        </p>
        <a class="button" id="last-bike-link" href="/de/motorrad-sitzbank/suzuki-gsx-s1000gx/">Weiter zum Guide</a>
      </article>

      <article class="notice">
        <h2>Warum diese Struktur?</h2>
        <p>
          Später bekommt jedes Motorrad eigene Sitzhöhe, Sitzbankoptionen, Quellen, Länderpriorität,
          Produktkarten und Erfahrungsberichte. Die Suzuki bleibt dein aktueller Startpunkt.
        </p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="page-inner">
      <p class="eyebrow">Aktiv</p>
      <h2>Bereits bearbeitete Modelle</h2>
      <div class="grid">
        {activeMotorcycles.map((motorcycle) => (
          <article class="card motorcycle-card">
            <span class="badge">{motorcycle.segment}</span>
            <h3>{motorcycle.name}</h3>
            <p><strong>Fokus:</strong> {motorcycle.seatPainFocus}</p>
            <p><strong>Warum jetzt:</strong> {motorcycle.whyNext}</p>
            <a class="button" href={motorcycle.path}>Guide öffnen</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section alt" id="geplant">
    <div class="page-inner">
      <p class="eyebrow">Roadmap</p>
      <h2>Geplante Motorradmodelle</h2>
      <p class="lead">
        Diese Modelle sind Platzhalter für die nächsten Daten- und Content-Sprints. Reihenfolge und Auswahl
        können wir nach Nachfrage, Land und Affiliate-Potenzial anpassen.
      </p>
      <div class="grid">
        {plannedMotorcycles.map((motorcycle) => (
          <article class="card motorcycle-card muted-card">
            <span class="badge muted">{motorcycle.brand}</span>
            <h3>{motorcycle.name}</h3>
            <p><strong>Segment:</strong> {motorcycle.segment}</p>
            <p><strong>Priorität:</strong> {motorcycle.countryPriority}</p>
            <p><strong>Sitzbank-Fokus:</strong> {motorcycle.seatPainFocus}</p>
            <span class="badge">geplant</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="technikprofile">
    <div class="page-inner">
      <p class="eyebrow">Technische Profile</p>
      <h2>Vorbereitet für spätere Komfort-Berechnungen.</h2>
      <p class="lead">
        Die Zahlen sind noch nicht verifiziert. Genau deshalb zeigt die Seite jetzt offen, welche Messungen
        fehlen, bevor Sitzdruck, Kniewinkel oder Langstreckenrisiko seriös berechnet werden.
      </p>
      <div class="lab-data-grid">
        {technicalProfiles.map((profile) => {
          const motorcycle = motorcyclesBySlug.get(profile.motorcycleSlug);
          return (
            <LabDataCard
              eyebrow={profile.ridingTriangleStatus === "research_needed" ? "Messung offen" : profile.ridingTriangleStatus}
              title={motorcycle?.name ?? profile.motorcycleSlug}
              summary={motorcycle?.seatPainFocus ?? profile.notes}
              badges={profile.usageProfile.map((item) => profileLabel[item] ?? item)}
              media={getMediaForEntity("motorcycle_profile", profile.motorcycleSlug)}
              facts={[
                { label: "Sitzhöhe", value: profile.seatHeightMm ? `${profile.seatHeightMm} mm` : "noch nicht verifiziert" },
                { label: "Gewicht nass", value: profile.wetWeightKg ? `${profile.wetWeightKg} kg` : "noch nicht verifiziert" },
                { label: "Hauptrisiken", value: profile.seatComfortRisks.map((item) => riskLabel[item] ?? item).join(", ") },
              ]}
              detailTitle="Benötigte Messungen"
              detailItems={[
                ...profile.requiredMeasurements.map((item) => measurementLabel[item] ?? item),
                profile.notes,
              ]}
              tone={profile.motorcycleSlug === "suzuki-gsx-s1000gx" ? "success" : "default"}
            />
          );
        })}
      </div>
    </div>
  </section>

  <script>
    const lastBike = window.localStorage.getItem("motoseatlab_last_motorcycle");
    const lastBikeTitle = document.querySelector("#last-bike-title");
    const lastBikeNote = document.querySelector("#last-bike-note");
    const lastBikeLink = document.querySelector("#last-bike-link");

    if (lastBike === "suzuki-gsx-s1000gx" && lastBikeTitle && lastBikeNote && lastBikeLink) {
      lastBikeTitle.textContent = "Suzuki GSX-S1000GX";
      lastBikeNote.textContent = "Du warst zuletzt im GSX-S1000GX Guide. Deshalb steht dieses Modell hier weiterhin an erster Stelle.";
      lastBikeLink.setAttribute("href", "/de/motorrad-sitzbank/suzuki-gsx-s1000gx/");
    }
  </script>
</BaseLayout>
