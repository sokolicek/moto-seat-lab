---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import LabDataCard from "../../../components/LabDataCard.astro";
import SeatLayerGraphic from "../../../components/SeatLayerGraphic.astro";
import YouTubeVideoCard from "../../../components/YouTubeVideoCard.astro";
import seatMaterials from "../../../data/materials/seat-materials.json";
import workshopTools from "../../../data/tools/seat-tools.json";
import workshopSupplies from "../../../data/supplies/seat-supplies.json";
import { getMediaForEntity } from "../../../lib/mediaAssets";
import { getVideosForEntity } from "../../../lib/videoResources";

const skillLabel: Record<string, string> = {
  beginner: "Einsteiger",
  intermediate: "mittel",
  advanced: "fortgeschritten",
  professional: "Sattler / Profi",
};

const priceLabel: Record<string, string> = {
  low_to_medium: "niedrig bis mittel",
  medium: "mittel",
  medium_to_high: "mittel bis hoch",
};

const researchLabel: Record<string, string> = {
  category_validated: "Kategorie plausibel",
  needs_product_testing: "Produkttest nötig",
  needs_specification: "Spezifikation offen",
  needs_testing: "Test nötig",
  needs_supplier_data: "Lieferantendaten nötig",
  needs_safety_review: "Sicherheitsprüfung nötig",
};

const foamMaterials = seatMaterials.filter((material) => material.materialType.includes("foam") || material.key.includes("foam"));
const diyVideos = getVideosForEntity("page_section", "de-diy-videos");
const videoMetadataPaths = [
  {
    title: "ohne API-Key",
    text: "YouTube oEmbed liefert in der Regel Titel, Kanal, Thumbnail und Embed-HTML. Es liefert aber keine vollständige Videobeschreibung.",
  },
  {
    title: "mit YouTube Data API",
    text: "videos.list mit part=snippet kann Titel, Beschreibung, Kanal, Tags und Thumbnails liefern. Dafür brauchen wir einen API-Key und müssen Quoten beachten.",
  },
  {
    title: "redaktionell",
    text: "Für Moto Seat Lab sollte ein kurzer eigener Nutzen-Text gespeichert werden: Was sieht man im Video, für wen ist es geeignet, wo sind die Grenzen?",
  },
];
---

<BaseLayout
  title="Motorradsitzbank DIY: sicher starten"
  description="DIY-Grundlagen für Motorradsitzbank Komfort: messen, dokumentieren, vorsichtig testen und die Originalsitzbank schützen."
  canonicalPath="/de/diy/"
>
  <section class="hero">
    <div class="page-inner">
      <p class="eyebrow">DIY mit Plan</p>
      <h1>Schneide nicht einfach Schaum weg.</h1>
      <p class="lead">
        Eine Sitzbank lässt sich verbessern, aber auch schnell ruinieren. Starte mit Messung, Fotos,
        Testfahrten und möglichst einer zweiten gebrauchten Sitzbank.
      </p>
      <div class="actions">
        <a class="button" href="#schaumstoffe">Peny verstehen</a>
        <a class="button secondary" href="#videos">Video-Kuration</a>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="page-inner grid two">
      <SeatLayerGraphic />
      <article class="card">
        <h2>Vorher dokumentieren</h2>
        <p>Fotos, Maße, Sitzhöhe, Breite und Druckpunkte festhalten. Ohne Ausgangspunkt kannst du keine Verbesserung beurteilen.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="page-inner grid">
      <article class="card">
        <h2>In Schichten denken</h2>
        <p>Stützschicht und Komfortschicht sind nicht dasselbe. Zu weicher Schaum kann auf langen Strecken schlechter werden.</p>
      </article>
      <article class="card">
        <h2>Wasser und Bezug ernst nehmen</h2>
        <p>Schlechter Bezug, falscher Kleber oder undichte Membran können den Sitz langfristig zerstören.</p>
      </article>
    </div>
  </section>

  <section class="section alt" id="schaumstoffe">
    <div class="page-inner">
      <p class="eyebrow">Spezialsektion · Schaumstoffe</p>
      <h2>Peny entscheiden über Druck, Höhe und Langstreckenkomfort.</h2>
      <p class="lead">
        Bei einer Sitzbank ist Schaum nicht einfach weich oder hart. Entscheidend ist, welche Lage trägt,
        welche Lage Druck verteilt, wie schnell sie zurückfedert und ob Wärme, Wasser oder Sitzhöhe zum Problem werden.
      </p>

      <div class="decision-strip">
        <span>
          <strong>1. Nicht zuerst schneiden</strong>
          Miss Sitzhöhe, Breite, Schmerzpunkt und Fahrdauer. Erst danach Material wählen.
        </span>
        <span>
          <strong>2. Schichten trennen</strong>
          Stützlage trägt Gewicht. Komfortlage verteilt Druck. Eine weiche Lage ersetzt keine stabile Basis.
        </span>
        <span>
          <strong>3. Testbar bleiben</strong>
          Wenn möglich mit Auflage, Testbezug oder Zweitsitzbank arbeiten, bevor der Originalsitz offen ist.
        </span>
      </div>

      <div class="foam-principles">
        <article class="mini-panel">
          <h3>Dichte</h3>
          <p>Mehr Dichte bedeutet nicht automatisch mehr Komfort, aber oft mehr Tragfähigkeit und Haltbarkeit.</p>
        </article>
        <article class="mini-panel">
          <h3>Stauchhärte</h3>
          <p>Sie beschreibt, wie stark Schaum unter Last nachgibt. Zu weich kann nach 60 Minuten durchdrücken.</p>
        </article>
        <article class="mini-panel">
          <h3>Rückstellung</h3>
          <p>Ein guter Sitz kehrt sauber zurück und bildet keine Mulde, die dich in eine falsche Position zwingt.</p>
        </article>
        <article class="mini-panel">
          <h3>Wärme</h3>
          <p>Memory Foam und Gel können angenehm sein, aber im Sommer oder bei langen Etappen Wärme stauen.</p>
        </article>
      </div>

      <div class="lab-data-grid">
        {foamMaterials.map((material) => (
          <LabDataCard
            eyebrow={material.materialType}
            title={material.name}
            summary={material.comfortRole}
            badges={[researchLabel[material.researchStatus] ?? material.researchStatus]}
            media={getMediaForEntity("seat_material", material.key)}
            facts={[
              { label: "Gut für", value: material.bestFor },
              { label: "Nicht ideal", value: material.avoidWhen },
              { label: "Skill", value: skillLabel[material.skillLevel] ?? material.skillLevel },
            ]}
            detailTitle="Haltbarkeit und Test"
            detailItems={[material.durabilityNotes]}
            tone={material.skillLevel === "professional" ? "warning" : "default"}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="videos">
    <div class="page-inner">
      <p class="eyebrow">YouTube · geplant als kuratierte Lernquelle</p>
      <h2>Videos erst verstehen, dann einbetten.</h2>
      <p class="lead">
        Ja, YouTube-Videos können direkt auf der Seite abgespielt werden. Für Moto Seat Lab ist aber wichtiger,
        vorher kurz zu speichern, was im Video wirklich gezeigt wird, für wen es passt und wo es gefährlich wird.
      </p>

      <div class="lab-data-grid compact">
        {videoMetadataPaths.map((path) => (
          <article class="card lab-data-card">
            <div class="card-topline">
              <span class="badge muted">Metadata</span>
            </div>
            <h3>{path.title}</h3>
            <p>{path.text}</p>
          </article>
        ))}
      </div>

      <div class="video-resource-grid">
        {diyVideos.map((video) => <YouTubeVideoCard video={video} />)}
      </div>
    </div>
  </section>

  <section class="section alt" id="materialien">
    <div class="page-inner">
      <p class="eyebrow">Aus der Materialdatenbank</p>
      <h2>Materialien: erst reversibel, dann schneiden.</h2>
      <p class="lead">
        Diese Liste ist noch keine Kaufempfehlung. Sie hilft dir, die richtige Klasse von Lösung zu wählen,
        bevor du Geld, Zeit oder die Originalsitzbank riskierst.
      </p>
      <div class="lab-data-grid">
        {seatMaterials.map((material) => (
          <LabDataCard
            eyebrow={material.materialType}
            title={material.name}
            summary={material.comfortRole}
            badges={[researchLabel[material.researchStatus] ?? material.researchStatus]}
            media={getMediaForEntity("seat_material", material.key)}
            facts={[
              { label: "Gut für", value: material.bestFor },
              { label: "Skill", value: skillLabel[material.skillLevel] ?? material.skillLevel },
              { label: "Preisband", value: priceLabel[material.priceBand] ?? material.priceBand },
            ]}
            detailTitle="Grenzen und Haltbarkeit"
            detailItems={[
              `Nicht ideal, wenn: ${material.avoidWhen}`,
              material.durabilityNotes,
            ]}
            tone={material.researchStatus.includes("safety") ? "warning" : "default"}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="werkzeug">
    <div class="page-inner">
      <p class="eyebrow">Werkstatt-Check</p>
      <h2>Werkzeug nach Risiko auswählen.</h2>
      <p class="lead">
        Nicht jedes Werkzeug gehört sofort in Anfängerhände. Die Seite soll später aus deinem Ziel,
        deiner Erfahrung und dem Sitzbankzustand automatisch einen sicheren Werkzeugpfad vorschlagen.
      </p>
      <div class="lab-data-grid compact">
        {workshopTools.map((tool) => (
          <LabDataCard
            eyebrow={tool.toolType}
            title={tool.name}
            summary={tool.usedFor}
            badges={[skillLabel[tool.skillLevel] ?? tool.skillLevel]}
            media={getMediaForEntity("workshop_tool", tool.key)}
            facts={[
              { label: "Nutzung", value: tool.usedFor },
              { label: "Kaufnotiz", value: tool.buyingNotes },
            ]}
            detailTitle="Risiko"
            detailItems={[tool.riskNotes]}
            tone={tool.skillLevel === "advanced" ? "warning" : "default"}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section alt" id="pruefmittel">
    <div class="page-inner">
      <p class="eyebrow">Präparate und Verbrauchsmaterial</p>
      <h2>Kleber, Klammern, Pflege und Abdichtung.</h2>
      <p class="lead">
        Diese Dinge entscheiden oft über Haltbarkeit, Wasserprobleme und saubere Verarbeitung.
        Auch hier gilt: erst Materialverträglichkeit prüfen, dann am echten Sitz arbeiten.
      </p>
      <div class="lab-data-grid compact">
        {workshopSupplies.map((supply) => (
          <LabDataCard
            eyebrow={supply.supplyType}
            title={supply.name}
            summary={supply.usedFor}
            badges={[skillLabel[supply.skillLevel] ?? supply.skillLevel]}
            media={getMediaForEntity("workshop_supply", supply.key)}
            facts={[
              { label: "Gut für", value: supply.bestFor },
              { label: "Kaufnotiz", value: supply.buyingNotes },
            ]}
            detailTitle="Risiko"
            detailItems={[supply.riskNotes]}
            tone={supply.skillLevel === "advanced" ? "warning" : "default"}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section alt" id="minimalprotokoll">
    <div class="page-inner">
      <h2>DIY-Minimalprotokoll</h2>
      <div class="comparison-table" role="table" aria-label="DIY Minimalprotokoll">
        <div class="comparison-row header" role="row">
          <span role="columnheader">Phase</span>
          <span role="columnheader">Ziel</span>
          <span role="columnheader">Was notieren?</span>
          <span role="columnheader">Abbruchsignal</span>
        </div>
        <div class="comparison-row" role="row">
          <span role="cell">Vorher</span>
          <span role="cell">Ausgangszustand sichern</span>
          <span role="cell">Fotos, Maße, Sitzhöhe, Schmerzstelle</span>
          <span role="cell">keine Vergleichsdaten vorhanden</span>
        </div>
        <div class="comparison-row" role="row">
          <span role="cell">Test</span>
          <span role="cell">reversible Änderung prüfen</span>
          <span role="cell">Dauer, Temperatur, Kleidung, Strecke</span>
          <span role="cell">Motorradgefühl wird unsicher</span>
        </div>
        <div class="comparison-row" role="row">
          <span role="cell">Umbau</span>
          <span role="cell">nur eine Variable ändern</span>
          <span role="cell">Material, Schichtdicke, Kleber, Bezug</span>
          <span role="cell">Wasser, Heizung, Sitzschloss oder Kontrolle betroffen</span>
        </div>
        <div class="comparison-row" role="row">
          <span role="cell">Nachher</span>
          <span role="cell">Verbesserung belegen</span>
          <span role="cell">gleiche Testfahrt und ehrlicher Vergleich</span>
          <span role="cell">neue Schmerzen oder schlechtere Kontrolle</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
