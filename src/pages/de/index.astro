---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DiagnosticMap from "../../components/DiagnosticMap.astro";
import MediaAssetFigure from "../../components/MediaAssetFigure.astro";
import { getMediaForEntity } from "../../lib/mediaAssets";

const visualStories = [
  {
    eyebrow: "Motorräder",
    title: "Vom Modell zum echten Problem.",
    text: "Starte mit deinem Motorradprofil und prüfe erst Fahrdauer, Sitzhaltung und typische Druckpunkte.",
    media: getMediaForEntity("motorcycle_profile", "suzuki-gsx-s1000gx", "hero"),
    href: "/de/motorrad-sitzbank/",
  },
  {
    eyebrow: "Sitze",
    title: "Nicht jeder Komfortsitz passt.",
    text: "OEM, Aftermarket und Sattler werden später nach Fitment, Rückgabe, Preis und Erfahrungsberichten getrennt.",
    media: getMediaForEntity("page_section", "home_seat_options"),
    href: "/de/kaufen/",
  },
  {
    eyebrow: "Schaum",
    title: "Komfort beginnt unter dem Bezug.",
    text: "Dichte, Stauchhärte, Schichten und Wärmeverhalten entscheiden, ob eine Änderung wirklich hilft.",
    media: getMediaForEntity("page_section", "home_foam_materials"),
    href: "/de/diy/#schaumstoffe",
  },
  {
    eyebrow: "Werkstatt",
    title: "DIY nur mit Plan und Werkzeugdisziplin.",
    text: "Erst messen und dokumentieren, dann reversible Tests, dann erst schneiden, kleben oder tackern.",
    media: getMediaForEntity("page_section", "home_tools"),
    href: "/de/diy/#werkzeug",
  },
];
---

<BaseLayout
  title="Moto Seat Lab Deutschland - Sitzbank Komfort"
  description="Praktische Hilfe für Motorradfahrer in Deutschland, deren Sitzbank nach kurzer Zeit unbequem wird."
  canonicalPath="/de/"
  imagePath="/assets/hero/touring-forest-curve.webp"
  preloadImagePath="/assets/hero/touring-forest-curve.webp"
>
  <section class="hero scenic-hero germany-hero">
    <div class="page-inner scenic-hero-inner">
      <div class="scenic-copy">
        <p class="eyebrow">Moto Seat Lab Deutschland</p>
        <h1>Deine Motorradsitzbank tut nach einer Stunde weh?</h1>
        <p class="lead">
          Starte nicht mit einem teuren Warenkorb. Starte mit Schmerzstelle, Fahrdauer,
          Sitzhaltung und einem kleinen Test, den du wirklich vergleichen kannst.
        </p>
        <div class="actions">
          <a class="button" href="/de/motorrad-sitzbank/suzuki-gsx-s1000gx/">Zuletzt: Suzuki GSX-S1000GX</a>
          <a class="button secondary" href="/de/motorrad-sitzbank/">Alle Motorradprofile</a>
          <a class="button secondary" href="/de/loesungen/">Lösungswege verstehen</a>
        </div>
        <div class="hero-stats" aria-label="Moto Seat Lab MVP Status">
          <span><strong>19 Profile</strong><small>über das Menü wählbar</small></span>
          <span><strong>3 Wege</strong><small>Auflage, Kauf, Sattler/DIY</small></span>
          <span><strong>0 Hype</strong><small>erst Ursache, dann Produkt</small></span>
        </div>
        <p class="asset-note">AI-generiertes Touring-Motiv für die lokale MVP-Version.</p>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="page-inner grid two">
      <DiagnosticMap />
      <article class="card">
        <h2>Warum diese Richtung?</h2>
        <p>
          Deutschland startet mit Touren, Landstraße und längeren Fahrten. Deshalb priorisieren wir
          Sitzdruck, Hitze, Rutschen und Ergonomie vor schnellen Produktversprechen.
        </p>
      </article>
    </div>
  </section>
  <section class="section alt">
    <div class="page-inner">
      <p class="eyebrow">Visueller Einstieg</p>
      <h2>Alles beginnt mit einem konkreten Sitzproblem.</h2>
      <p class="lead">
        Die Seite soll dich nicht mit Tabellen erschlagen. Du startest visuell und einfach:
        Motorrad, Lösung, Material oder Werkzeug.
      </p>
      <div class="visual-story-grid">
        {visualStories.map((story) => (
          <a class="visual-story-card" href={story.href}>
            {story.media && <MediaAssetFigure asset={story.media} variant="card" showCredit={false} />}
            <div>
              <span class="badge muted">{story.eyebrow}</span>
              <h3>{story.title}</h3>
              <p>{story.text}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
  <section class="section visual-band">
    <div class="page-inner grid three-feature">
      <article>
        <span class="metric">Start</span>
        <h2>Für Anfänger verständlich.</h2>
        <p>Keine Materialtabellen am Anfang. Erst die Frage: was tut wann, wo und unter welchen Bedingungen weh?</p>
      </article>
      <article>
        <span class="metric">Praxis</span>
        <h2>Erst reversible Tests.</h2>
        <p>Kleidung, 3D-Mesh, Luftkissen oder Sitzposition können helfen, bevor die originale Bank geöffnet wird.</p>
      </article>
      <article>
        <span class="metric">Tiefe</span>
        <h2>Dann Daten und Vergleich.</h2>
        <p>Wenn einfache Tests nicht reichen, kommen Sitzhöhe, Schaum, Anatomie, Sattler und Produktdaten dazu.</p>
      </article>
    </div>
  </section>
  <section class="section alt">
    <div class="page-inner grid">
      <article class="card">
        <h2>Erst verstehen</h2>
        <p>Hart, weich, rutschig, heiß oder Druckpunkt? Die Ursache entscheidet, nicht der Preis.</p>
      </article>
      <article class="card">
        <h2>Dann vergleichen</h2>
        <p>Eine teure Sitzbank kann passen, muss aber nicht. Rückgabe, Körperbau und Fahrstil zählen.</p>
      </article>
      <article class="card">
        <h2>Dann testen</h2>
        <p>Wenn du unsicher bist, starte mit reversiblen Tests, bevor du die originale Sitzbank veränderst.</p>
      </article>
    </div>
  </section>
  <section class="section">
    <div class="page-inner grid two">
      <article class="notice">
        <h2>Aktueller MVP-Fokus</h2>
        <p>
          Der erste echte Guide ist bewusst eng: Deutschland, Deutsch, Suzuki GSX-S1000GX
          und Sitzbankprobleme nach etwa einer Stunde.
        </p>
      </article>
      <article class="card">
        <h2>Was noch nicht fertig ist</h2>
        <p>
          Konkrete Produktkarten, Preise, Affiliate-Links und belastbare Rankings kommen erst nach Quellenprüfung.
          Bis dahin bleibt die Empfehlung transparent und vorsichtig.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
