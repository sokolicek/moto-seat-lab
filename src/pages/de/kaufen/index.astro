---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import LabDataCard from "../../../components/LabDataCard.astro";
import ProductCategoryCard from "../../../components/ProductCategoryCard.astro";
import SeatOptionCard from "../../../components/SeatOptionCard.astro";
import productCategories from "../../../data/product-categories/seat-comfort.json";
import seatOptions from "../../../data/products/gsx-s1000gx-seat-options.json";
import buyingChannels from "../../../data/marketplaces/de.json";
import disclosures from "../../../data/disclosures/de.json";

const affiliateLabel: Record<string, string> = {
  low: "Affiliate niedrig",
  medium: "Affiliate möglich",
  high: "Affiliate stark",
  service_directory: "Service-Verzeichnis",
};

const channelLabel: Record<string, string> = {
  oem_dealer: "OEM Händler",
  marketplace: "Marktplatz",
  motorcycle_retailer: "Motorradhandel",
  service_provider: "Sattler / Service",
};
---

<BaseLayout
  title="Motorradsitzbank kaufen: Deutschland Guide"
  description="Kaufpfade für Motorrad Sitzbank Komfort in Deutschland: Produktkategorien, Grenzen, Quellen und Affiliate-Hinweise."
  canonicalPath="/de/kaufen/"
>
  <section class="hero">
    <div class="page-inner">
      <p class="eyebrow">Kaufen ohne Nebel</p>
      <h1>Was kaufen, wenn die Sitzbank unbequem ist?</h1>
      <p class="lead">
        Starte nicht mit dem teuersten Produkt. Starte mit Problem, Rückgabemöglichkeit und Passform.
      </p>
      <div class="actions">
        <a class="button" href="#kaufmatrix">Kaufmatrix ansehen</a>
        <a class="button secondary" href="/de/motorrad-sitzbank/suzuki-gsx-s1000gx/">GSX-S1000GX Guide</a>
      </div>
    </div>
  </section>

  <section class="section alt" id="kaufmatrix">
    <div class="page-inner">
      <h2>Einfacher Kaufpfad</h2>
      <div class="timeline">
        <article class="timeline-item">
          <span>1</span>
          <div>
            <h3>Problem benennen</h3>
            <p>Druck, Hitze, Rutschen, Knie/Hüfte oder Soziuskomfort sind verschiedene Kaufentscheidungen.</p>
          </div>
        </article>
        <article class="timeline-item">
          <span>2</span>
          <div>
            <h3>Reversibel testen</h3>
            <p>Erst günstige, rückbaubare Maßnahmen testen. Danach weißt du, ob teurer Kauf Sinn ergibt.</p>
          </div>
        </article>
        <article class="timeline-item">
          <span>3</span>
          <div>
            <h3>Passform und Rückgabe prüfen</h3>
            <p>Teilenummer, Modelljahr, Sitzhöhe, Montage und Rückgaberegeln sind wichtiger als Werbetexte.</p>
          </div>
        </article>
        <article class="timeline-item">
          <span>4</span>
          <div>
            <h3>Ergebnis dokumentieren</h3>
            <p>Gleiche Strecke, gleiche Kleidung, ähnliche Temperatur. Sonst vergleichst du Gefühle, keine Lösung.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="page-inner grid">
      {productCategories.map((category) => <ProductCategoryCard {...category} />)}
    </div>
  </section>

  <section class="section alt" id="kaufkanaele">
    <div class="page-inner">
      <p class="eyebrow">Deutschland Datenbank</p>
      <h2>Kaufkanäle nach Zweck, nicht nach Werbung.</h2>
      <p class="lead">
        Der Kaufpfad trennt bewusst OEM, Marktplatz, Motorradhandel und Sattler. So kann Moto Seat Lab später
        echte Preise, Rückgabe, Affiliate-Status und Vertrauensniveau sauber vergleichen.
      </p>
      <div class="lab-data-grid">
        {buyingChannels.map((channel) => (
          <LabDataCard
            eyebrow={channelLabel[channel.channelType] ?? channel.channelType}
            title={channel.name}
            summary={channel.bestFor}
            badges={[affiliateLabel[channel.affiliatePotential] ?? channel.affiliatePotential]}
            facts={[
              { label: "Land", value: channel.country },
              { label: "Vertrauen", value: `${channel.trustLevel}/5` },
              { label: "Am besten für", value: channel.bestFor },
            ]}
            detailTitle="Notiz für spätere Produktkarten"
            detailItems={[channel.notes]}
            tone={channel.trustLevel >= 4 ? "success" : "default"}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="page-inner">
      <p class="eyebrow">GSX-S1000GX Beispiel</p>
      <h2>Erste Produkt- und Servicekandidaten</h2>
      <p class="lead">
        So soll die Kaufseite später arbeiten: nicht “bestes Produkt” behaupten, sondern Fitment,
        Risiko, Preisnotiz, Quelle und Vertrauensniveau nebeneinander zeigen.
      </p>
      <div class="grid two">
        {seatOptions.map((option) => <SeatOptionCard {...option} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="page-inner grid two">
      <article class="notice">
        <h2>Noch keine echten Produkt-Rankings</h2>
        <p>
          Diese Seite ist absichtlich ehrlich: konkrete Produkte, Preise und Affiliate-Links werden erst ergänzt,
          wenn Passform, Lieferbarkeit, Rückgabe und Erfahrungsberichte geprüft sind.
        </p>
      </article>
      <article class="card">
        <h2>Späteres Datenmodell</h2>
        <p>
          Jede Empfehlung soll später Hersteller, Teilenummer, Preisbereich, Land, Modelljahr, Rückgabe,
          Quelle, Affiliate-Status und Vertrauensniveau enthalten.
        </p>
      </article>
    </div>
  </section>

  <section class="section alt">
    <div class="page-inner notice">
      <h2>Affiliate-Hinweis</h2>
      <p>{disclosures.affiliate}</p>
      <p>{disclosures.fitment}</p>
    </div>
  </section>
</BaseLayout>
