---
import BaseLayout from "../../layouts/BaseLayout.astro";
import countries from "../../data/i18n/countries.json";
import { getCopy, getCountryHreflang, getCountrySeatIntelligence, getLocalizedHome } from "../../lib/i18n";

export function getStaticPaths() {
  return countries
    .filter((country) => country.code !== "de")
    .map((country) => ({
      params: { country: country.code },
      props: { country },
    }));
}

const { country } = Astro.props;
const home = getLocalizedHome(country.code);
const intelligence = getCountrySeatIntelligence(country.code);
const t = (key: string) => getCopy(country.primaryLanguage, key);
const countryAlternates = countries.map((item) => ({
  lang: getCountryHreflang(item),
  path: item.defaultPath,
}));
const translatedUiExamples = [
  t("nav.start"),
  t("nav.motorcycles"),
  t("nav.solutions"),
  t("nav.buying"),
  t("nav.diy"),
  t("footer.privacy"),
];
---

<BaseLayout
  title={home.title}
  description={home.description}
  canonicalPath={country.defaultPath}
  imagePath="/assets/hero/touring-forest-curve.webp"
  preloadImagePath="/assets/hero/touring-forest-curve.webp"
  locale={country.primaryLanguage}
  alternates={countryAlternates}
>
  <section class="hero scenic-hero">
    <div class="page-inner scenic-hero-inner">
      <div class="scenic-copy">
        <p class="eyebrow">{country.flagEmoji} {home.eyebrow}</p>
        <h1>{home.headline}</h1>
        <p class="lead">{home.lead}</p>
        <div class="actions">
          <a class="button" href="/de/">{home.primaryAction}</a>
          <a class="button secondary" href="/de/motorrad-sitzbank/">{home.secondaryAction}</a>
        </div>
        <div class="hero-stats" aria-label={`${country.nativeName} localization status`}>
          <span><strong>{country.flagEmoji}</strong><small>{country.nativeName}</small></span>
          <span><strong>{country.primaryLanguage.toUpperCase()}</strong><small>{country.region}</small></span>
          <span><strong>{country.currency}</strong><small>{country.marketTier.replaceAll("_", " ")}</small></span>
        </div>
        <p class="asset-note">{home.assetNote}</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="page-inner grid two">
      <article class="card">
        <p class="eyebrow">{home.strategyEyebrow}</p>
        <h2>{home.strategyTitle}</h2>
        <p>{home.strategyText}</p>
      </article>
      <article class="card">
        <p class="eyebrow">{home.priorityEyebrow}</p>
        <h2>{home.priorityTitle}</h2>
        <ul class="check-list">
          {home.priorities.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  {intelligence && (
    <section class="section alt">
      <div class="page-inner">
        <p class="eyebrow">{country.flagEmoji} Country Intelligence</p>
        <h2>{home.priorityTitle}</h2>
        <p class="lead">{intelligence.firstRecommendation}</p>
        <div class="country-intel-grid">
          <article class="card">
            <p class="eyebrow">Pain points</p>
            <h3>What riders here probably need first</h3>
            <ul class="check-list">
              {intelligence.primaryPainPoints.map((item) => <li>{item}</li>)}
            </ul>
          </article>
          <article class="card">
            <p class="eyebrow">Motorcycles</p>
            <h3>Lead segments</h3>
            <div class="tag-cloud">
              {intelligence.leadMotorcycleSegments.map((item) => <span>{item}</span>)}
            </div>
            <p>{intelligence.budgetLogic}</p>
          </article>
          <article class="card">
            <p class="eyebrow">Buying logic</p>
            <h3>Show these options early</h3>
            <ol class="ranked-list">
              {intelligence.buyingPriorities.map((item) => <li>{item}</li>)}
            </ol>
          </article>
          <article class="card">
            <p class="eyebrow">Forums and tests</p>
            <h3>Local research sources</h3>
            <ul class="source-list">
              {intelligence.forumSources.map((source) => (
                <li>
                  <a href={source.url}>{source.name}</a>
                  <span>{source.language}</span>
                  <small>{source.note}</small>
                </li>
              ))}
            </ul>
          </article>
        </div>
      </div>
    </section>
  )}

  <section class="section alt">
    <div class="page-inner">
      <p class="eyebrow">{t("locale.panelTitle")}</p>
      <h2>{t("brand.subtitle")}</h2>
      <p class="lead">{home.lead}</p>
      <div class="visual-story-grid compact">
        {translatedUiExamples.map((label) => (
          <article class="mini-info-card">
            <strong>{label}</strong>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
