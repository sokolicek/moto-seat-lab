---
import BaseLayout from "../../layouts/BaseLayout.astro";

const countryPriorities = [
  "Najprv lacná a vratná úľava: 3D mesh, gélová alebo vzduchová podložka.",
  "Potom porovnanie so sériovým sedlom a dostupnými komfortnými sedlami.",
  "Až nakoniec čalúnnik alebo DIY zásah, keď má jazdec zmerané, kde ho sedlo tlačí.",
];
---

<BaseLayout
  title="Moto Seat Lab Slovensko - návrh lokalizácie"
  description="Prvá slovenská lokalizačná kostra pre Moto Seat Lab: pohodlie sedla, rýchla úľava, čalúnnik a DIY."
  canonicalPath="/sk/"
  imagePath="/assets/hero/touring-forest-curve.webp"
  preloadImagePath="/assets/hero/touring-forest-curve.webp"
  locale="sk"
>
  <section class="hero scenic-hero">
    <div class="page-inner scenic-hero-inner">
      <div class="scenic-copy">
        <p class="eyebrow">Moto Seat Lab Slovensko · návrh</p>
        <h1>Bolí ťa sedlo po hodine jazdy?</h1>
        <p class="lead">
          Slovenská verzia bude priamočiarejšia: najprv rýchla úľava za rozumné peniaze,
          potom porovnanie sediel a až potom zásah do peny alebo poťahu.
        </p>
        <div class="actions">
          <a class="button" href="/de/motorrad-sitzbank/suzuki-gsx-s1000gx/">Pozrieť aktuálny nemecký MVP</a>
          <a class="button secondary" href="/de/motorrad-sitzbank/">Zoznam motoriek</a>
        </div>
        <p class="asset-note">Toto je draft jazykovej mutácie. Dáta krajiny sú už pripravené v databázovej štruktúre.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="page-inner grid two">
      <article class="card">
        <p class="eyebrow">Lokálna stratégia</p>
        <h2>Čo bude mať slovenská verzia iné?</h2>
        <p>
          Nebude automaticky tlačiť drahé prémiové sedlá. Pre bežného jazdca má väčší zmysel
          začať lacným testom, lokálnym čalúnnikom a jasným meraním problému.
        </p>
      </article>
      <article class="card">
        <p class="eyebrow">Poradie odporúčaní</p>
        <h2>Salámová metóda namiesto expert módu</h2>
        <ul class="check-list">
          {countryPriorities.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>
