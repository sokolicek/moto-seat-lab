---
import { getCopy, getLocaleFromPath } from "../lib/i18n";

interface Props {
  locale?: string;
}

const locale = Astro.props.locale ?? getLocaleFromPath(Astro.url.pathname);
const t = (key: string) => getCopy(locale, key);
---

<aside class="cookie-bar" id="cookie-bar" aria-label={t("cookie.label")}>
  <strong>Cookies</strong>
  <p>{t("cookie.text")}</p>
  <div class="cookie-actions">
    <button class="primary" type="button" data-cookie-choice="optional">{t("cookie.optional")}</button>
    <button type="button" data-cookie-choice="necessary">{t("cookie.necessary")}</button>
    <a class="button secondary" href="/de/cookies/">{t("cookie.details")}</a>
  </div>
</aside>

<script>
  const bar = document.querySelector("#cookie-bar");
  const stored = window.localStorage.getItem("motoseatlab_cookie_choice");
  if (stored && bar) {
    bar.setAttribute("hidden", "");
  }

  document.querySelectorAll("[data-cookie-choice]").forEach((button) => {
    button.addEventListener("click", () => {
      const choice = button.getAttribute("data-cookie-choice") || "necessary";
      window.localStorage.setItem("motoseatlab_cookie_choice", choice);
      bar?.setAttribute("hidden", "");
    });
  });
</script>
