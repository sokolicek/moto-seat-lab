---
interface Props {
  name: string;
  maker: string;
  type: string;
  fitment: string;
  market: string;
  priceNote: string;
  bestFor: string;
  watchOut: string;
  comfortLogic: string;
  researchStatus: string;
  confidence: number;
  affiliateStatus: string;
  imagePath?: string;
  imageAlt?: string;
  sourceLabel: string;
  sourceUrl: string;
}

const {
  name,
  maker,
  type,
  fitment,
  market,
  priceNote,
  bestFor,
  watchOut,
  comfortLogic,
  researchStatus,
  confidence,
  affiliateStatus,
  imagePath,
  imageAlt = "",
  sourceLabel,
  sourceUrl
} = Astro.props;
---

<article class="card seat-option-card">
  {imagePath && (
    <figure class="option-card-media">
      <img src={imagePath} alt={imageAlt} loading="lazy" />
    </figure>
  )}
  <div class="card-topline">
    <span class="badge">{maker}</span>
    <span class="badge muted">{type}</span>
    <span class="badge confidence">Confidence {confidence}/5</span>
  </div>
  <h3>{name}</h3>
  <p><strong>Passt zu:</strong> {fitment}</p>
  <p><strong>Sinnvoll für:</strong> {bestFor}</p>
  <div class="quick-facts">
    <span><strong>Markt</strong>{market}</span>
    <span><strong>Preis</strong>{priceNote}</span>
  </div>
  <details class="card-details">
    <summary>Risiko und Komfort-Logik</summary>
    <p><strong>Aufpassen:</strong> {watchOut}</p>
    <p><strong>Komfort-Logik:</strong> {comfortLogic}</p>
  </details>
  <div class="card-footer-line">
    <span>{researchStatus}</span>
    <span>{affiliateStatus}</span>
  </div>
  <p class="source-link"><a href={sourceUrl}>{sourceLabel}</a></p>
</article>
