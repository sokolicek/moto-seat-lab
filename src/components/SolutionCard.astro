---
import type { MediaAsset } from "../lib/mediaAssets";
import MediaAssetFigure from "./MediaAssetFigure.astro";

interface Props {
  title: string;
  summary: string;
  bestFor: string;
  notIdealFor: string;
  cost: string;
  confidence: string;
  media?: MediaAsset;
}

const { title, summary, bestFor, notIdealFor, cost, confidence, media } = Astro.props;
---

<article class="card solution-card">
  {media && <MediaAssetFigure asset={media} variant="card" />}
  <span class="badge">{confidence}</span>
  <h3>{title}</h3>
  <p>{summary}</p>
  <div class="quick-facts">
    <span><strong>Gut für</strong>{bestFor}</span>
    <span><strong>Kosten</strong>{cost}</span>
  </div>
  <details class="card-details">
    <summary>Grenzen anzeigen</summary>
    <p><strong>Nicht ideal für:</strong> {notIdealFor}</p>
  </details>
</article>
