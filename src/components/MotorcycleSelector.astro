---
import motorcycles from "../data/motorcycles/de-list.json";

interface Props {
  currentSlug?: string;
  compact?: boolean;
}

const { currentSlug = "suzuki-gsx-s1000gx", compact = false } = Astro.props;

const slugFromMotorcycle = (motorcycle: (typeof motorcycles)[number]) =>
  motorcycle.path.split("/").filter(Boolean).at(-1) ?? motorcycle.name.toLowerCase().replaceAll("/", "").replaceAll(" ", "-");
---

<section class={`card motorcycle-selector ${compact ? "compact" : ""}`} aria-labelledby="motorcycle-selector-title">
  <div>
    <p class="eyebrow">Motorrad wählen</p>
    <h2 id="motorcycle-selector-title">Mit welchem Motorrad willst du starten?</h2>
    <p>
      Suzuki GSX-S1000GX ist aktuell aktiv. Die anderen Modelle sind vorbereitet und werden nach und nach
      mit Daten, Bildern und Sitzbankoptionen gefüllt.
    </p>
  </div>

  <form class="motorcycle-selector-form" data-motorcycle-selector>
    <label class="field" for="motorcycle-select">
      <span>Modell</span>
      <select id="motorcycle-select" name="motorcycle">
        {motorcycles.map((motorcycle) => {
          const slug = slugFromMotorcycle(motorcycle);
          const enabled = Boolean(motorcycle.path);
          const statusLabel = motorcycle.status === "active" ? "" : motorcycle.status === "draft" ? "· Basisprofil" : "· geplant";
          return (
            <option
              value={enabled ? motorcycle.path : `/de/motorrad-sitzbank/#geplant`}
              data-status={motorcycle.status}
              data-name={motorcycle.name}
              data-segment={motorcycle.segment}
              data-focus={motorcycle.seatPainFocus}
              data-why={motorcycle.whyNext}
              selected={slug === currentSlug}
            >
              {motorcycle.name} {statusLabel}
            </option>
          );
        })}
      </select>
    </label>
    <button class="button" type="submit">Öffnen</button>
    <a class="button secondary" href="/de/motorrad-sitzbank/">Alle Motorräder</a>
  </form>

  <div class="motorcycle-selector-result" data-motorcycle-selector-result aria-live="polite"></div>
</section>

<script>
  document.querySelectorAll<HTMLFormElement>("[data-motorcycle-selector]").forEach((form) => {
    const shell = form.closest(".motorcycle-selector");
    const result = shell?.querySelector<HTMLElement>("[data-motorcycle-selector-result]");
    const select = form.querySelector<HTMLSelectElement>("select[name='motorcycle']");

    const renderSelection = () => {
      const option = select?.selectedOptions[0];
      if (!option || !result) return;

      const status = option.dataset.status || "planned";
      const name = option.dataset.name || option.textContent?.trim() || "Motorrad";
      const segment = option.dataset.segment || "";
      const focus = option.dataset.focus || "";
      const why = option.dataset.why || "";

      if (status === "active") {
        result.className = "motorcycle-selector-result active";
        result.innerHTML = `
          <span class="badge">Aktiv</span>
          <strong>${name}</strong>
          <p>${focus}</p>
        `;
        return;
      }

      if (status === "draft") {
        result.className = "motorcycle-selector-result basis-profile";
        result.innerHTML = `
          <span class="badge">Basisprofil</span>
          <strong>${name}</strong>
          <p><strong>${segment}</strong> · ${focus}</p>
          <p>${why}</p>
          <p class="muted-line">Öffne das Basisprofil: Daten, Risiken und erste Messpunkte sind vorbereitet, Produktrecherche ist noch offen.</p>
        `;
        return;
      }

      result.className = "motorcycle-selector-result planned";
      result.innerHTML = `
        <span class="badge confidence">Geplant</span>
        <strong>${name}</strong>
        <p><strong>${segment}</strong> · ${focus}</p>
        <p>${why}</p>
        <p class="muted-line">Noch kein eigener Guide. Du kannst die Roadmap öffnen oder mit Suzuki als Referenzmodell weiterarbeiten.</p>
      `;
    };

    renderSelection();
    select?.addEventListener("change", renderSelection);

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const option = select?.selectedOptions[0];
      const status = option?.dataset.status || "planned";
      const target = select?.value || "/de/motorrad-sitzbank/";
      if (status === "planned") {
        renderSelection();
        if (target.includes("#")) {
          window.location.href = target;
        }
        return;
      }
      window.location.href = target;
    });
  });
</script>
