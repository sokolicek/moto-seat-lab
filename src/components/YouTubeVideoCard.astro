---
interface VideoResource {
  key: string;
  status: string;
  topic: string;
  youtubeVideoId: string;
  youtubeUrl: string;
  providerUrl?: string;
  sourcePageUrl?: string;
  title: string;
  channelName: string;
  language: string;
  duration: string;
  thumbnailUrl: string;
  fetchedDescription: string;
  editorSummary: string;
  whatToLookFor: string[];
  fitFor: string[];
  riskNotes: string;
  embedPolicy: string;
}

interface Props {
  video: VideoResource;
}

const { video } = Astro.props;
const hasEmbed = Boolean(video.youtubeVideoId);
const hasThumbnail = Boolean(video.thumbnailUrl);
const isVerified = video.status.startsWith("verified");
const externalUrl = video.youtubeUrl || video.providerUrl || video.sourcePageUrl || "";
---

<article class={`card video-resource-card ${hasEmbed ? "playable" : "curation"}`}>
  <div class="card-topline">
    <span class="badge muted">{video.topic}</span>
    <span class="badge">{hasEmbed ? (isVerified ? "Video bereit" : "Embed prüfen") : "Kuration offen"}</span>
    <span class="badge muted">{video.language.toUpperCase()}</span>
  </div>

  <h3>{video.title}</h3>
  <p>{video.editorSummary}</p>

  {
    hasThumbnail && (
      <div class="video-player-shell">
        <button
          class="video-thumbnail video-thumbnail-button"
          type="button"
          data-youtube-id={video.youtubeVideoId}
          data-youtube-title={video.title}
          disabled={!hasEmbed}
        >
          <img
            src={video.thumbnailUrl}
            alt={`YouTube thumbnail: ${video.title}`}
            loading="lazy"
          />
          <span>{hasEmbed ? "Auf dieser Seite abspielen" : "Video noch nicht ausgewählt"}</span>
        </button>
        {hasEmbed && <div class="youtube-frame" hidden></div>}
      </div>
    )
  }

  {
    hasEmbed && !hasThumbnail ? (
      <div class="youtube-embed-shell">
        <button class="youtube-load-button" type="button" data-youtube-id={video.youtubeVideoId} data-youtube-title={video.title}>
          Video laden und abspielen
        </button>
        <div class="youtube-frame" hidden></div>
      </div>
    ) : !hasEmbed ? (
      <div class="video-placeholder" aria-label="Video noch nicht kuratiert">
        <strong>Video noch nicht ausgewählt</strong>
        <span>Erst Quelle, Einbettbarkeit, Sprache und Nutzen prüfen.</span>
        {externalUrl && (
          <a class="inline-source-link" href={externalUrl} target="_blank" rel="noreferrer">
            Quellenkandidat öffnen
          </a>
        )}
      </div>
    ) : null
  }

  <div class="quick-facts compact-facts">
    <span>
      <strong>Kurzbeschreibung</strong>
      {video.fetchedDescription || "Noch nicht aus YouTube-Metadaten übernommen."}
    </span>
    <span>
      <strong>Quelle</strong>
      {video.channelName || "Kanal noch offen"}
    </span>
    <span>
      <strong>Status</strong>
      {video.status}
    </span>
  </div>

  <details class="card-details" open>
    <summary>Was soll man im Video finden?</summary>
    <ul class="compact-list">
      {video.whatToLookFor.map((item) => <li>{item}</li>)}
    </ul>
  </details>

  <details class="card-details">
    <summary>Grenzen und Einbettung</summary>
    <ul class="compact-list">
      <li>{video.riskNotes}</li>
      <li>{video.embedPolicy}</li>
      {video.sourcePageUrl && (
        <li>
          Quellenkontext: <a href={video.sourcePageUrl} target="_blank" rel="noreferrer">öffnen</a>
        </li>
      )}
    </ul>
  </details>
</article>

<script>
  document.querySelectorAll(".video-thumbnail img").forEach((image) => {
    image.addEventListener("error", () => {
      if (!(image instanceof HTMLImageElement)) return;
      image.hidden = true;
      image.closest(".video-thumbnail")?.classList.add("thumbnail-missing");
    });
  });

  const buildEmbedUrl = (id: string) => {
    const params = new URLSearchParams({
      rel: "0",
      modestbranding: "1",
      playsinline: "1",
      autoplay: "1",
      origin: window.location.origin,
    });
    return `https://www.youtube-nocookie.com/embed/${encodeURIComponent(id)}?${params.toString()}`;
  };

  const loadVideo = (button: Element) => {
    if (!(button instanceof HTMLButtonElement)) return;
    const card = button.closest(".video-resource-card");
    const frameShell = card?.querySelector(".youtube-frame");
    const loadButton = card?.querySelector(".youtube-load-button");
    const thumbnailButton = card?.querySelector(".video-thumbnail-button");
    const id = button.dataset.youtubeId;
    const title = button.dataset.youtubeTitle ?? "YouTube video";
    if (!id || !(frameShell instanceof HTMLElement)) return;
    if (!frameShell.querySelector("iframe")) {
      const iframe = document.createElement("iframe");
      iframe.src = buildEmbedUrl(id);
      iframe.title = title;
      iframe.loading = "lazy";
      iframe.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
      iframe.allowFullscreen = true;
      iframe.referrerPolicy = "strict-origin-when-cross-origin";
      frameShell.append(iframe);
    }
    frameShell.hidden = false;
    if (loadButton instanceof HTMLButtonElement) loadButton.hidden = true;
    if (thumbnailButton instanceof HTMLButtonElement) thumbnailButton.hidden = true;
  };

  document.querySelectorAll(".youtube-load-button, .video-thumbnail-button").forEach((button) => {
    button.addEventListener("click", () => {
      loadVideo(button);
    });
  });
</script>
