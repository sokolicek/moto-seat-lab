---
interface VideoResource {
  key: string;
  status: string;
  topic: string;
  youtubeVideoId: string;
  youtubeUrl: string;
  sourcePageUrl?: string;
  title: string;
  channelName: string;
  language: string;
  duration: string;
  thumbnailUrl: string;
  fetchedDescription: string;
  editorSummary: string;
  whatToLookFor: string[];
  fitFor: string[];
  riskNotes: string;
  embedPolicy: string;
}

interface Props {
  video: VideoResource;
}

const { video } = Astro.props;
const hasEmbed = Boolean(video.youtubeVideoId);
const embedUrl = hasEmbed
  ? `https://www.youtube-nocookie.com/embed/${video.youtubeVideoId}?rel=0&modestbranding=1`
  : "";
---

<article class={`card video-resource-card ${hasEmbed ? "playable" : "curation"}`}>
  <div class="card-topline">
    <span class="badge muted">{video.topic}</span>
    <span class="badge">{hasEmbed ? "Video bereit" : "Kuration offen"}</span>
    <span class="badge muted">{video.language.toUpperCase()}</span>
  </div>

  <h3>{video.title}</h3>
  <p>{video.editorSummary}</p>

  {
    video.thumbnailUrl && (
      <a class="video-thumbnail" href={video.youtubeUrl} target="_blank" rel="noreferrer">
        <img
          src={video.thumbnailUrl}
          alt={`YouTube thumbnail: ${video.title}`}
          loading="lazy"
        />
        <span>Auf YouTube öffnen</span>
      </a>
    )
  }

  {
    hasEmbed ? (
      <div class="youtube-embed-shell">
        <button class="youtube-load-button" type="button" data-youtube-src={embedUrl} data-youtube-title={video.title}>
          Video laden und abspielen
        </button>
        <div class="youtube-frame" hidden></div>
      </div>
    ) : (
      <div class="video-placeholder" aria-label="Video noch nicht kuratiert">
        <strong>Video noch nicht ausgewählt</strong>
        <span>Erst Quelle, Einbettbarkeit, Sprache und Nutzen prüfen.</span>
      </div>
    )
  }

  <div class="quick-facts compact-facts">
    <span>
      <strong>Kurzbeschreibung</strong>
      {video.fetchedDescription || "Noch nicht aus YouTube-Metadaten übernommen."}
    </span>
    <span>
      <strong>Quelle</strong>
      {video.channelName || "Kanal noch offen"}
    </span>
    <span>
      <strong>Status</strong>
      {video.status}
    </span>
  </div>

  <details class="card-details" open>
    <summary>Was soll man im Video finden?</summary>
    <ul class="compact-list">
      {video.whatToLookFor.map((item) => <li>{item}</li>)}
    </ul>
  </details>

  <details class="card-details">
    <summary>Grenzen und Einbettung</summary>
    <ul class="compact-list">
      <li>{video.riskNotes}</li>
      <li>{video.embedPolicy}</li>
      {video.sourcePageUrl && (
        <li>
          Quellenkontext: <a href={video.sourcePageUrl} target="_blank" rel="noreferrer">öffnen</a>
        </li>
      )}
    </ul>
  </details>
</article>

<script>
  document.querySelectorAll(".video-thumbnail img").forEach((image) => {
    image.addEventListener("error", () => {
      if (!(image instanceof HTMLImageElement)) return;
      image.hidden = true;
      image.closest(".video-thumbnail")?.classList.add("thumbnail-missing");
    });
  });

  document.querySelectorAll(".youtube-load-button").forEach((button) => {
    button.addEventListener("click", () => {
      if (!(button instanceof HTMLButtonElement)) return;
      const frameShell = button.nextElementSibling;
      const src = button.dataset.youtubeSrc;
      const title = button.dataset.youtubeTitle ?? "YouTube video";
      if (!src || !(frameShell instanceof HTMLElement)) return;
      if (!frameShell.querySelector("iframe")) {
        const iframe = document.createElement("iframe");
        iframe.src = src;
        iframe.title = title;
        iframe.loading = "lazy";
        iframe.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
        iframe.allowFullscreen = true;
        iframe.referrerPolicy = "strict-origin-when-cross-origin";
        frameShell.append(iframe);
      }
      frameShell.hidden = false;
      button.hidden = true;
    });
  });
</script>
