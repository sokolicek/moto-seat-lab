---
import "../styles/global.css";
import CookieBar from "../components/CookieBar.astro";
import motorcycles from "../data/motorcycles/de-list.json";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  imagePath?: string;
  preloadImagePath?: string;
}

const { title, description, canonicalPath = "/", imagePath, preloadImagePath } = Astro.props;
const canonical = new URL(canonicalPath, Astro.site ?? "https://motoseatlab.com").toString();
const image = imagePath ? new URL(imagePath, Astro.site ?? "https://motoseatlab.com").toString() : undefined;
const currentPath = Astro.url.pathname;
const menuMotorcycles = motorcycles.filter((motorcycle) => motorcycle.path);
const referenceMotorcycle = menuMotorcycles.find((motorcycle) => motorcycle.status === "active") ?? menuMotorcycles[0];
const currentMotorcycle =
  menuMotorcycles.find((motorcycle) => motorcycle.path === currentPath) ?? referenceMotorcycle;
const motorcycleStatusLabel: Record<string, string> = {
  active: "Guide",
  draft: "Basisprofil",
  planned: "geplant",
};
const motorcycleGroups = Array.from(
  menuMotorcycles.reduce((groups, motorcycle) => {
    const group = groups.get(motorcycle.brand) ?? [];
    group.push(motorcycle);
    groups.set(motorcycle.brand, group);
    return groups;
  }, new Map<string, typeof menuMotorcycles>())
);
const slugFromPath = (path: string) => path.split("/").filter(Boolean).at(-1) ?? "";
const buyingShortcuts = [
  { label: "Kaufen Übersicht", href: "/de/kaufen/", note: "Startseite für Kaufentscheidungen" },
  { label: "Schnelle Hilfe", href: "/de/kaufen/#schnellhilfe", note: "Auflage, Mesh, Gel, Airpad" },
  { label: "Kaufmatrix", href: "/de/kaufen/#kaufmatrix", note: "Problem, Rückgabe, Passform" },
  { label: "Kaufkanäle", href: "/de/kaufen/#kaufkanaele", note: "OEM, Händler, Marktplatz, Sattler" },
  { label: "Produktkarten", href: "/de/kaufen/#produktkandidaten", note: "Beispiele mit Quelle und Risiko" },
];
const diyShortcuts = [
  { label: "DIY Übersicht", href: "/de/diy/", note: "Sicher starten" },
  { label: "Schaumstoffe", href: "/de/diy/#schaumstoffe", note: "Dichte, Härte, Schichten" },
  { label: "Videos", href: "/de/diy/#videos", note: "YouTube kuratieren und einbetten" },
  { label: "Materialien", href: "/de/diy/#materialien", note: "Schaum, Gel, Mesh, Bezug" },
  { label: "Werkzeug", href: "/de/diy/#werkzeug", note: "Was du wirklich brauchst" },
  { label: "Präparate", href: "/de/diy/#pruefmittel", note: "Kleber, Klammern, Pflege" },
  { label: "Minimalprotokoll", href: "/de/diy/#minimalprotokoll", note: "Messen, testen, dokumentieren" },
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {preloadImagePath && <link rel="preload" as="image" href={preloadImagePath} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    {image && <meta property="og:image" content={image} />}
    {image && <meta property="og:image:alt" content="Touring motorcycle riding through a forest road curve." />}
    <meta name="twitter:card" content={image ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={image} />}
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="nav-inner">
          <a class="brand" href="/de/" aria-label="Moto Seat Lab Startseite">
            <span class="brand-mark" aria-hidden="true"><span></span></span>
            <span>
              <strong>Moto Seat Lab</strong>
              <small>Sitzkomfort ohne Blindkauf</small>
            </span>
          </a>
          <nav class="nav-links" aria-label="Hauptnavigation">
            <a href="/de/">Start</a>
            <details class="nav-dropdown">
              <summary>
                <span>Motorräder</span>
                <span class="dropdown-caret" aria-hidden="true"></span>
              </summary>
              <div class="dropdown-panel">
                <div class="dropdown-head">
                  <strong>{menuMotorcycles.length} Motorräder</strong>
                  <a href="/de/motorrad-sitzbank/">Alle Modelle ansehen</a>
                </div>
                {currentMotorcycle && (
                  <a
                    class="dropdown-featured-bike"
                    href={currentMotorcycle.path}
                    data-motorcycle-link
                    data-motorcycle-slug={slugFromPath(currentMotorcycle.path)}
                    data-motorcycle-name={currentMotorcycle.name}
                  >
                    <span class="badge">{currentMotorcycle.path === currentPath ? "Aktuell gewählt" : "Zuletzt gewählt"}</span>
                    <strong>{currentMotorcycle.name}</strong>
                    <small>{currentMotorcycle.seatPainFocus}</small>
                  </a>
                )}
                <div class="dropdown-brand-list">
                  {motorcycleGroups.map(([brand, brandMotorcycles]) => (
                    <section class="dropdown-brand-group" aria-label={`${brand} Modelle`}>
                      <h3>{brand}</h3>
                      <div class="dropdown-list">
                        {brandMotorcycles.map((motorcycle) => {
                          const isCurrent = motorcycle.path === currentPath;
                          return (
                            <a
                              class={`dropdown-bike ${motorcycle.status} ${isCurrent ? "current" : ""}`}
                              href={motorcycle.path}
                              aria-current={isCurrent ? "page" : undefined}
                              data-motorcycle-link
                              data-motorcycle-slug={slugFromPath(motorcycle.path)}
                              data-motorcycle-name={motorcycle.name}
                            >
                              <span>
                                <strong>{motorcycle.name}</strong>
                                <small>{motorcycle.segment} · {motorcycle.countryPriority}</small>
                              </span>
                              <em>{isCurrent ? "Aktuell" : motorcycleStatusLabel[motorcycle.status] ?? "Öffnen"}</em>
                            </a>
                          );
                        })}
                      </div>
                    </section>
                  ))}
                </div>
                {referenceMotorcycle && (
                  <div class="dropdown-foot">
                    <a
                      href={referenceMotorcycle.path}
                      data-motorcycle-link
                      data-motorcycle-slug={slugFromPath(referenceMotorcycle.path)}
                      data-motorcycle-name={referenceMotorcycle.name}
                    >
                      Suzuki GSX-S1000GX öffnen
                    </a>
                    <span>Basisprofile sind bewusst ehrlich markiert, bis Produktdaten geprüft sind.</span>
                  </div>
                )}
              </div>
            </details>
            <a href="/de/loesungen/">Lösungen</a>
            <details class="nav-dropdown shortcut-dropdown">
              <summary>
                <span>Kaufen</span>
                <span class="dropdown-caret" aria-hidden="true"></span>
              </summary>
              <div class="dropdown-panel shortcut-panel">
                <div class="dropdown-head">
                  <strong>Kaufpfade</strong>
                  <a href="/de/kaufen/">Zur Kaufseite</a>
                </div>
                <div class="dropdown-shortcuts">
                  {buyingShortcuts.map((shortcut) => (
                    <a class="dropdown-shortcut" href={shortcut.href}>
                      <strong>{shortcut.label}</strong>
                      <span>{shortcut.note}</span>
                    </a>
                  ))}
                </div>
              </div>
            </details>
            <details class="nav-dropdown shortcut-dropdown">
              <summary>
                <span>DIY</span>
                <span class="dropdown-caret" aria-hidden="true"></span>
              </summary>
              <div class="dropdown-panel shortcut-panel">
                <div class="dropdown-head">
                  <strong>DIY-Schnellzugriff</strong>
                  <a href="/de/diy/">Zur DIY-Seite</a>
                </div>
                <div class="dropdown-shortcuts">
                  {diyShortcuts.map((shortcut) => (
                    <a class="dropdown-shortcut" href={shortcut.href}>
                      <strong>{shortcut.label}</strong>
                      <span>{shortcut.note}</span>
                    </a>
                  ))}
                </div>
              </div>
            </details>
            <a href="/de/bilder/">Bilder</a>
          </nav>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div class="page-inner footer-grid">
          <div class="footer-brand">
            <strong>Moto Seat Lab</strong>
            <p>
              Unabhängiges Konzeptprojekt für Sitzkomfort, Recherche und klare Kaufentscheidungen.
              Keine Empfehlung ist eine Garantie für Passform, Komfort oder medizinische Wirkung.
            </p>
            <p class="footer-small">
              MVP-Status: lokale Entwicklung, keine aktiven Werbenetzwerke, keine bezahlten Affiliate-Links.
            </p>
          </div>
          <nav class="footer-links" aria-label="Rechtliche Hinweise">
            <a href="/de/datenschutz/">
              <strong>Datenschutz</strong>
              <span>Welche Daten aktuell nicht und später nur transparent verarbeitet werden.</span>
            </a>
            <a href="/de/cookies/">
              <strong>Cookies</strong>
              <span>Minimaler Cookie-Hinweis, lokale Speicherung und geplante Optionen.</span>
            </a>
            <a href="/de/impressum/">
              <strong>Impressum</strong>
              <span>Betreiberangaben vor Veröffentlichung ergänzen und rechtlich prüfen.</span>
            </a>
          </nav>
        </div>
      </footer>
    </div>
    <CookieBar />
    <script>
      const dropdowns = document.querySelectorAll(".nav-dropdown");

      dropdowns.forEach((dropdown) => {
        dropdown.addEventListener("toggle", () => {
          if (!(dropdown instanceof HTMLDetailsElement) || !dropdown.open) return;
          dropdowns.forEach((otherDropdown) => {
            if (otherDropdown !== dropdown && otherDropdown instanceof HTMLDetailsElement) {
              otherDropdown.open = false;
            }
          });
        });
      });

      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (target.closest(".nav-dropdown")) return;
        dropdowns.forEach((dropdown) => {
          if (dropdown instanceof HTMLDetailsElement) dropdown.open = false;
        });
      });

      document.querySelectorAll("[data-motorcycle-link]").forEach((link) => {
        link.addEventListener("click", () => {
          if (!(link instanceof HTMLElement)) return;
          const slug = link.dataset.motorcycleSlug;
          const name = link.dataset.motorcycleName;
          if (!slug) return;
          window.localStorage.setItem("motoseatlab_last_motorcycle", slug);
          if (name) window.localStorage.setItem("motoseatlab_last_motorcycle_name", name);
        });
      });
    </script>
  </body>
</html>
