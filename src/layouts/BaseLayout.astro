---
import "../styles/global.css";
import CookieBar from "../components/CookieBar.astro";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  imagePath?: string;
  preloadImagePath?: string;
}

const { title, description, canonicalPath = "/", imagePath, preloadImagePath } = Astro.props;
const canonical = new URL(canonicalPath, Astro.site ?? "https://motoseatlab.com").toString();
const image = imagePath ? new URL(imagePath, Astro.site ?? "https://motoseatlab.com").toString() : undefined;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {preloadImagePath && <link rel="preload" as="image" href={preloadImagePath} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    {image && <meta property="og:image" content={image} />}
    {image && <meta property="og:image:alt" content="Touring motorcycle riding through a forest road curve." />}
    <meta name="twitter:card" content={image ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={image} />}
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="nav-inner">
          <a class="brand" href="/de/">Moto Seat Lab</a>
          <nav class="nav-links" aria-label="Hauptnavigation">
            <a href="/de/motorrad-sitzbank/suzuki-gsx-s1000gx/">GSX-S1000GX</a>
            <a href="/de/loesungen/">Lösungen</a>
            <a href="/de/kaufen/">Kaufen</a>
            <a href="/de/diy/">DIY</a>
          </nav>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div class="page-inner">
          <p>
            Moto Seat Lab ist ein unabhängiges Konzeptprojekt. Empfehlungen sind keine Garantie für Passform,
            Komfort oder medizinische Wirkung.
          </p>
          <p>
            <a href="/de/datenschutz/">Datenschutz</a> ·
            <a href="/de/cookies/">Cookies</a> ·
            <a href="/de/impressum/">Impressum</a>
          </p>
        </div>
      </footer>
    </div>
    <CookieBar />
  </body>
</html>
